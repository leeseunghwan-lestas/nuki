{
  "manifest_version": 3,
  "name": "nuki (Beta)",
  "version": "1.1.0",
  "description": "画面上の任意の領域からテキストを抽出 — Gemini AI によって提供されています / Extract text from any area on screen — powered by Gemini AI",
  "permissions": [
    "activeTab",
    "storage",
    "clipboardWrite",
    "sidePanel",
    "offscreen",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>",
    "file:///*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "incognito": "spanning",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "pages/popup/popup.html"
  },
  "options_page": "pages/options/options.html",
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+E",
        "mac": "Command+Shift+E"
      },
      "description": "Open side panel"
    },
    "capture-area": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Capture area to extract text"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
